/* ===================================
   GLOBAL RESPONSIVE STYLES - FIXED
   =================================== */

@media (max-width: 768px) {
  .card:not(.modern-card), 
  .glass-card {
    padding: 0.1rem;
  }

  /* ✅ استثناء جداول الـ modern من التعديلات */
  .table-responsive-sm:not(.table-container-modern) {
    display: block;
    width: 100%;
    overflow-x: auto; /* ✅ غيّرناها من hidden لـ auto */
  }

  .table:not(.table-modern) {
    font-size: 0.75rem;
  }

  .table:not(.table-modern) th, 
  .table:not(.table-modern) td {
    padding: 0.4rem;
  }

  .btn:not(.btn-modern) {
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
  }

  .form-control:not(.form-control-modern), 
  .form-select:not(.form-select-modern) {
    font-size: 0.9rem;
  }

  h2 {
    font-size: 1.5rem;
  }

  h3 {
    font-size: 1.25rem;
  }
}

@media (max-width: 576px) {
  .container:not(.admin-branches-container) {
    padding: 0.3rem;
  }

  /* ✅ استثناء الجداول الحديثة من التحويل لـ block */
  .table:not(.table-modern) {
    display: block;
    width: 100%;
  }

  /* ❌ إزالة إخفاء الـ thead - غير ضروري */
  /* .table thead {
    display: none;
  } */

  .table:not(.table-modern) tbody tr {
    display: block;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid #dee2e6;
  }

  .table:not(.table-modern) td {
    display: block;
    text-align: right;
    padding: 0.3rem 0.5rem;
    position: relative;
    padding-right: 45%; /* ✅ مساحة للـ label */
  }

  .table:not(.table-modern) td:before {
    content: attr(data-label);
    font-weight: bold;
    position: absolute;
    right: 0.5rem;
    color: var(--primary-teal);
    width: 40%;
  }

  [lang="ar"] .table:not(.table-modern) td {
    text-align: left;
    padding-left: 45%;
    padding-right: 0.5rem;
  }

  [lang="ar"] .table:not(.table-modern) td:before {
    left: 0.5rem;
    right: auto;
  }

  /* ✅ استايل خاص بالجدول الحديث للشاشات الصغيرة */
  .table-container-modern {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .table-modern {
    min-width: 800px; /* ✅ يضمن عدم تشوه الجدول */
  }

  .table-modern thead th {
    font-size: 0.75rem;
    padding: 0.75rem 0.5rem;
  }

  .table-modern tbody td {
    font-size: 0.8rem;
    padding: 0.75rem 0.5rem;
  }

  /* ✅ تصغير الأزرار في الجدول */
  .table-modern .btn-modern {
    padding: 0.4rem 0.6rem !important;
    font-size: 0.75rem !important;
  }

  .table-modern .btn-modern i {
    font-size: 0.75rem;
  }

  /* ✅ تحسين Badge */
  .badge-modern {
    padding: 0.3rem 0.5rem;
    font-size: 0.7rem;
  }
}

/* ✅ استايل إضافي للشاشات الصغيرة جداً */
@media (max-width: 400px) {
  .table-modern {
    min-width: 700px;
  }

  .admin-branches-container {
    padding: 0.75rem;
  }

  .modern-card-body {
    padding: 1rem !important;
  }

  .page-header h2 {
    font-size: 1.25rem;
  }
}

/* ✅ حل مشكلة تداخل Cards */
@media (max-width: 768px) {
  .card:not(.modern-card) {
    margin: 1rem;
    max-width: calc(100% - 2rem) !important;
  }
  
  .card-header:not(.modern-card-header) {
    padding: 1.5rem !important;
  }
  
  .btn:not(.btn-modern) {
    padding: 0.8rem !important;
    font-size: 0.8rem !important;
  }
  
  .card-header:not(.modern-card-header) img {
    width: 3rem !important;
    height: 3rem !important;
  }

  /* ✅ تحسين المسافات للبطاقات الحديثة */
  .modern-card {
    margin-bottom: 1.5rem;
  }
}